<Window x:Class="Chess3D.App.Wpf.Views.PromotionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Promotion"
        Width="460"
        Height="245"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="#0A0F15"
        Foreground="#E7EDF6"
        FontFamily="Segoe UI Variable Display, Segoe UI, Arial">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBgBrush" Color="#0A0F15" />
        <SolidColorBrush x:Key="CardBrush" Color="#121B26" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#26384A" />
        <SolidColorBrush x:Key="TileBrush" Color="#16212D" />
        <SolidColorBrush x:Key="TileHoverBrush" Color="#1C2C3D" />
        <SolidColorBrush x:Key="TileBorderBrush" Color="#2A3B4D" />
        <SolidColorBrush x:Key="AccentBrush" Color="#78B7FF" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#173149" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E7EDF6" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A9B5C4" />

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="CaptionStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource TileBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TileBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Content}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource TileHoverBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.92" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBgBrush}">
        <Border Margin="18"
                Padding="18"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Choisir la pièce de promotion"
                               FontSize="22"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Sélectionne la pièce qui remplacera ton pion :"
                               Margin="0,6,0,0"
                               HorizontalAlignment="Center"
                               Style="{StaticResource CaptionStyle}" />
                </StackPanel>

                <UniformGrid Grid.Row="2"
                             Rows="1"
                             Columns="4">
                    <Button Content="Dame"
                            Tag="Queen"
                            Click="PromotionButton_Click" />
                    <Button Content="Tour"
                            Tag="Rook"
                            Click="PromotionButton_Click" />
                    <Button Content="Fou"
                            Tag="Bishop"
                            Click="PromotionButton_Click" />
                    <Button Content="Cavalier"
                            Tag="Knight"
                            Click="PromotionButton_Click" />
                </UniformGrid>
            </Grid>
        </Border>
    </Grid>
</Window>