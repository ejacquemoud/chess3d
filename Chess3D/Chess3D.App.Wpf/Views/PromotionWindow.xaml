<Window x:Class="Chess3D.App.Wpf.Views.PromotionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Promotion"
        Height="180"
        Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="#FF1E1E1E"
        Foreground="White">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Choisir la pièce de promotion"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"
                   HorizontalAlignment="Center" />

        <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="0,8,0,0">
            <Button Content="Dame" Tag="Queen" Margin="6" Padding="12,10" Click="PromotionButton_Click" />
            <Button Content="Tour" Tag="Rook" Margin="6" Padding="12,10" Click="PromotionButton_Click" />
            <Button Content="Fou" Tag="Bishop" Margin="6" Padding="12,10" Click="PromotionButton_Click" />
            <Button Content="Cavalier" Tag="Knight" Margin="6" Padding="12,10" Click="PromotionButton_Click" />
        </UniformGrid>
    </Grid>
</Window>