<Window x:Class="Chess3D.App.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chess 3D"
        Height="900"
        Width="1400"
        Background="Black"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Menu">
                <MenuItem Header="_Nouvelle partie" Click="NewGame_Click" />
            </MenuItem>
        </Menu>
        <Grid x:Name="Root"
              Background="Black"
              MouseLeftButtonDown="Root_MouseLeftButtonDown">
            <Viewport3D x:Name="Viewport"
                        ClipToBounds="True">
                <Viewport3D.Camera>
                    <PerspectiveCamera x:Name="Camera"
                                       Position="0,10,13"
                                       LookDirection="0,-8,-13"
                                       UpDirection="0,1,0"
                                       FieldOfView="60" />
                </Viewport3D.Camera>
            </Viewport3D>
        </Grid>
    </DockPanel>
</Window>