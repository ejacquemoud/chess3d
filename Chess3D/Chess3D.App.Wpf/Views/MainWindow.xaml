<Window x:Class="Chess3D.App.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chess 3D"
        Height="900"
        Width="1400"
        Background="#111214"
        Foreground="#EDEEF2"
        FontFamily="Segoe UI Variable Display, Segoe UI, Arial"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="WindowBgBrush" Color="#111214" />
        <SolidColorBrush x:Key="ChromeBrush" Color="#17181C" />
        <SolidColorBrush x:Key="ChromeBorderBrush" Color="#252629" />

        <SolidColorBrush x:Key="PopupBrush" Color="#1C1D21" />
        <SolidColorBrush x:Key="PopupBorderBrush" Color="#2C2E34" />

        <SolidColorBrush x:Key="HoverBrush" Color="#222428" />
        <SolidColorBrush x:Key="PressedBrush" Color="#2A2C32" />

        <SolidColorBrush x:Key="StatusBarBrush" Color="#141517" />
        <SolidColorBrush x:Key="StatusBarBorderBrush" Color="#222428" />

        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#EDEEF2" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8E9098" />
        <SolidColorBrush x:Key="TextDisabledBrush" Color="#555760" />

        <SolidColorBrush x:Key="AccentBrush" Color="#C9A84C" />
        <SolidColorBrush x:Key="SeparatorBrush" Color="#2C2E34" />
        <SolidColorBrush x:Key="ViewportBorderBrush" Color="#222428" />

        <!-- Fenêtre -->
        <Style TargetType="{x:Type Window}">
            <Setter Property="Background" Value="{StaticResource WindowBgBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="Auto" />
        </Style>

        <!-- Menu -->
        <Style TargetType="{x:Type Menu}">
            <Setter Property="Background" Value="{StaticResource ChromeBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ChromeBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <!-- Separator -->
        <Style TargetType="{x:Type Separator}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="1"
                                Margin="14,8,14,8"
                                Background="{StaticResource SeparatorBrush}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- StatusBar -->
        <Style TargetType="{x:Type StatusBar}">
            <Setter Property="Background" Value="{StaticResource StatusBarBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="{x:Type StatusBarItem}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="StatusPrimaryTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="StatusMutedTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="StatusChipBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#1A1C1F" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="StatusValueOnlyTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#A8ABB5" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="StatusBarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Height" Value="32" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="RootBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="10"
                        Height="{TemplateBinding Height}"
                        SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#262830" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#AA3A3C44" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#2E3038" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#484A54" />
                            </Trigger>

                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#484A54" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextDisabledBrush}" />
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- MenuItem -->
        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource ChromeBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Margin="0"
                                SnapsToDevicePixels="True">
                            <Grid x:Name="LayoutRoot" Height="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="CheckColumn" Width="24" />
                                    <ColumnDefinition x:Name="HeaderColumn" Width="*" />
                                    <ColumnDefinition x:Name="ArrowColumn" Width="16" />
                                </Grid.ColumnDefinitions>

                                <Grid x:Name="CheckHost"
                                      Grid.Column="0"
                                      Width="24"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed">
                                    <Border x:Name="CheckBadge"
                                            Width="14"
                                            Height="14"
                                            CornerRadius="7"
                                            Background="#1E2024"
                                            BorderBrush="#2E3038"
                                            BorderThickness="1">
                                        <Path x:Name="CheckGlyph"
                                              Data="M 3 7 L 5.8 9.8 L 11 4.8"
                                              Stroke="{StaticResource AccentBrush}"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Visibility="Collapsed" />
                                    </Border>
                                </Grid>

                                <ContentPresenter x:Name="HeaderHost"
                                                  Grid.Column="1"
                                                  Margin="6,0,6,0"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"
                                                  ContentSource="Header" />

                                <Path x:Name="ArrowGlyph"
                                      Grid.Column="2"
                                      Data="M 5 4 L 9 8 L 5 12"
                                      Stroke="{StaticResource TextSecondaryBrush}"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Width="12"
                                      Height="12"
                                      Stretch="None"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed" />

                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Placement="Bottom"
                                       PopupAnimation="Fade">
                                    <Border Background="{StaticResource PopupBrush}"
                                            BorderBrush="{StaticResource PopupBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            Margin="0,6,0,0"
                                            SnapsToDevicePixels="True">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="22"
                                                              ShadowDepth="0"
                                                              Opacity="0.22"
                                                              Color="#000000" />
                                        </Border.Effect>

                                        <Grid>
                                            <Border Width="26"
                                                    HorizontalAlignment="Left"
                                                    Background="#1E2024"
                                                    CornerRadius="16,0,0,16"
                                                    IsHitTestVisible="False" />

                                            <StackPanel IsItemsHost="True"
                                                        Margin="10"
                                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                                        </Grid>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter Property="Background" Value="{StaticResource ChromeBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
                                <Setter TargetName="CheckHost" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="ArrowGlyph" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="CheckColumn" Property="Width" Value="0" />
                                <Setter TargetName="ArrowColumn" Property="Width" Value="0" />
                                <Setter TargetName="RootBorder" Property="CornerRadius" Value="10" />
                                <Setter TargetName="RootBorder" Property="Margin" Value="0" />
                                <Setter TargetName="LayoutRoot" Property="Height" Value="24" />
                                <Setter TargetName="HeaderHost" Property="Margin" Value="6,0,6,0" />
                                <Setter TargetName="HeaderHost" Property="HorizontalAlignment" Value="Center" />
                            </Trigger>

                            <Trigger Property="Role" Value="TopLevelItem">
                                <Setter Property="Background" Value="{StaticResource ChromeBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                <Setter TargetName="CheckHost" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="ArrowGlyph" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="CheckColumn" Property="Width" Value="0" />
                                <Setter TargetName="ArrowColumn" Property="Width" Value="0" />
                                <Setter TargetName="LayoutRoot" Property="Height" Value="24" />
                                <Setter TargetName="HeaderHost" Property="Margin" Value="6,0,6,0" />
                                <Setter TargetName="HeaderHost" Property="HorizontalAlignment" Value="Center" />
                            </Trigger>

                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="FontWeight" Value="Normal" />
                                <Setter TargetName="CheckColumn" Property="Width" Value="24" />
                                <Setter TargetName="ArrowColumn" Property="Width" Value="16" />
                                <Setter TargetName="RootBorder" Property="Margin" Value="0,2" />
                                <Setter TargetName="RootBorder" Property="CornerRadius" Value="9" />
                                <Setter TargetName="LayoutRoot" Property="Height" Value="30" />
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Right" />
                                <Setter TargetName="PART_Popup" Property="HorizontalOffset" Value="8" />
                                <Setter TargetName="HeaderHost" Property="HorizontalAlignment" Value="Left" />
                                <Setter TargetName="HeaderHost" Property="Margin" Value="8,0,12,0" />
                            </Trigger>

                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="FontWeight" Value="Normal" />
                                <Setter TargetName="CheckColumn" Property="Width" Value="24" />
                                <Setter TargetName="ArrowColumn" Property="Width" Value="16" />
                                <Setter TargetName="RootBorder" Property="Margin" Value="0,2" />
                                <Setter TargetName="RootBorder" Property="CornerRadius" Value="9" />
                                <Setter TargetName="LayoutRoot" Property="Height" Value="30" />
                                <Setter TargetName="ArrowGlyph" Property="Visibility" Value="Visible" />
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Right" />
                                <Setter TargetName="PART_Popup" Property="HorizontalOffset" Value="8" />
                                <Setter TargetName="HeaderHost" Property="HorizontalAlignment" Value="Left" />
                                <Setter TargetName="HeaderHost" Property="Margin" Value="8,0,12,0" />
                            </Trigger>

                            <Trigger Property="IsCheckable" Value="True">
                                <Setter TargetName="CheckHost" Property="Visibility" Value="Visible" />
                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBadge" Property="Background" Value="#222428" />
                                <Setter TargetName="CheckBadge" Property="BorderBrush" Value="#3A3C44" />
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>

                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource HoverBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#3A3C44" />
                            </Trigger>

                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource PressedBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#3A3C44" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextDisabledBrush}" />
                                <Setter TargetName="ArrowGlyph" Property="Stroke" Value="{StaticResource TextDisabledBrush}" />
                                <Setter TargetName="CheckBadge" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True"
               Background="{StaticResource WindowBgBrush}">

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Partie">
                <MenuItem Header="_Nouvelle partie"
                          Click="NewGame_Click" />
                <Separator />
                <MenuItem x:Name="VersusCpuMenuItem"
                          Header="Jouer contre le _CPU"
                          IsCheckable="True"
                          Click="VersusCpuMenuItem_Click" />
                <MenuItem x:Name="LocalTwoPlayersMenuItem"
                          Header="Mode _2 joueurs locaux"
                          IsCheckable="True"
                          Click="LocalTwoPlayersMenuItem_Click" />
                <Separator />
                <MenuItem x:Name="PlayWhiteMenuItem"
                          Header="Je joue les _Blancs"
                          IsCheckable="True"
                          Click="PlayWhiteMenuItem_Click" />
                <MenuItem x:Name="PlayBlackMenuItem"
                          Header="Je joue les _Noirs"
                          IsCheckable="True"
                          Click="PlayBlackMenuItem_Click" />
                <Separator />
                <MenuItem Header="_Quitter"
                          Click="Quit_Click" />
            </MenuItem>

            <MenuItem Header="_Niveau CPU">
                <MenuItem x:Name="CpuLevel1MenuItem" Header="Niveau _1" IsCheckable="True" Click="CpuLevel1MenuItem_Click" />
                <MenuItem x:Name="CpuLevel2MenuItem" Header="Niveau _2" IsCheckable="True" Click="CpuLevel2MenuItem_Click" />
                <MenuItem x:Name="CpuLevel3MenuItem" Header="Niveau _3" IsCheckable="True" Click="CpuLevel3MenuItem_Click" />
                <MenuItem x:Name="CpuLevel4MenuItem" Header="Niveau _4" IsCheckable="True" Click="CpuLevel4MenuItem_Click" />
                <MenuItem x:Name="CpuLevel5MenuItem" Header="Niveau _5" IsCheckable="True" Click="CpuLevel5MenuItem_Click" />
                <MenuItem x:Name="CpuLevel6MenuItem" Header="Niveau _6" IsCheckable="True" Click="CpuLevel6MenuItem_Click" />
                <MenuItem x:Name="CpuLevel7MenuItem" Header="Niveau _7" IsCheckable="True" Click="CpuLevel7MenuItem_Click" />
                <MenuItem x:Name="CpuLevel8MenuItem" Header="Niveau _8" IsCheckable="True" Click="CpuLevel8MenuItem_Click" />
                <MenuItem x:Name="CpuLevel9MenuItem" Header="Niveau _9" IsCheckable="True" Click="CpuLevel9MenuItem_Click" />
                <MenuItem x:Name="CpuLevel10MenuItem" Header="Niveau _10" IsCheckable="True" Click="CpuLevel10MenuItem_Click" />
            </MenuItem>

            <MenuItem Header="_Aide">
                <MenuItem Header="_À propos"
                          Click="About_Click" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom"
           Padding="8,5,12,5">
            <StatusBarItem HorizontalContentAlignment="Stretch">
                <Grid HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                    Style="{StaticResource StatusChipBorderStyle}">
                        <TextBlock x:Name="StatusTextBlock"
                           Style="{StaticResource StatusValueOnlyTextStyle}"
                           Text="Tour : Blancs" />
                    </Border>

                    <Border Grid.Column="2"
                    Style="{StaticResource StatusChipBorderStyle}">
                        <TextBlock x:Name="SelectionTextBlock"
                           Style="{StaticResource StatusValueOnlyTextStyle}"
                           Text="Aucune sélection" />
                    </Border>

                    <Border Grid.Column="4"
                    Style="{StaticResource StatusChipBorderStyle}"
                    HorizontalAlignment="Stretch">
                        <TextBlock x:Name="ViewModeTextBlock"
                           Style="{StaticResource StatusValueOnlyTextStyle}"
                           Text="Mode : 2 joueurs locaux" />
                    </Border>

                    <Button Grid.Column="6"
                    Style="{StaticResource StatusBarButtonStyle}"
                    Click="ResetCamera_Click"
                    ToolTip="Réinitialiser la caméra">
                        <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                            <Grid Width="16"
                          Height="16"
                          Margin="0,0,8,0">
                                <Path Data="M 8 1.8 A 6.2 6.2 0 1 0 14.2 8"
                              Stroke="{StaticResource AccentBrush}"
                              StrokeThickness="1.7"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Stretch="Fill" />
                                <Path Data="M 11.5 1.6 L 14.4 1.6 L 14.4 4.5"
                              Stroke="{StaticResource AccentBrush}"
                              StrokeThickness="1.7"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Stretch="Fill" />
                            </Grid>

                            <TextBlock Text="Caméra"
                               Style="{StaticResource StatusValueOnlyTextStyle}"
                               VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="10">
            <Border CornerRadius="16"
                    Background="#111214"
                    BorderBrush="{StaticResource ViewportBorderBrush}"
                    BorderThickness="1">
                <Grid x:Name="Root"
                      Background="Black"
                      MouseLeftButtonDown="Root_MouseLeftButtonDown">
                    <Viewport3D x:Name="Viewport"
                                ClipToBounds="True">
                        <Viewport3D.Camera>
                            <PerspectiveCamera x:Name="Camera"
                                               Position="0,10,13"
                                               LookDirection="0,-8,-13"
                                               UpDirection="0,1,0"
                                               FieldOfView="60" />
                        </Viewport3D.Camera>
                    </Viewport3D>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
