<Window x:Class="Chess3D.App.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chess 3D"
        Height="900"
        Width="1400"
        Background="#111315"
        Foreground="#F2F2F2"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#111315" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#171A1D" />
        <SolidColorBrush x:Key="PanelBackgroundAltBrush" Color="#1D2126" />
        <SolidColorBrush x:Key="BorderBrushDark" Color="#2D333B" />
        <SolidColorBrush x:Key="ForegroundPrimaryBrush" Color="#F2F2F2" />
        <SolidColorBrush x:Key="ForegroundMutedBrush" Color="#B8C0CC" />
        <SolidColorBrush x:Key="AccentBrush" Color="#4DA3FF" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#67B2FF" />
        <SolidColorBrush x:Key="MenuHoverBrush" Color="#232933" />
        <SolidColorBrush x:Key="MenuPressedBrush" Color="#2B3440" />
        <SolidColorBrush x:Key="StatusBackgroundBrush" Color="#15181C" />

        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundPrimaryBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <ContentPresenter ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center" />
                                <Popup x:Name="PART_Popup"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       PopupAnimation="Fade">
                                    <Border Background="{StaticResource PanelBackgroundAltBrush}"
                                            BorderBrush="{StaticResource BorderBrushDark}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="4"
                                            SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Cycle" />
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource MenuHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource MenuPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource MenuPressedBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6E7681" />
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Margin" Value="6,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                Background="{StaticResource BorderBrushDark}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="StatusBar">
            <Setter Property="Background" Value="{StaticResource StatusBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1,1,0,0" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style TargetType="StatusBarItem">
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundMutedBrush}" />
        </Style>

        <Style x:Key="StatusValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ForegroundPrimaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <DockPanel Background="{StaticResource WindowBackgroundBrush}">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Menu">
                <MenuItem Header="_Nouvelle partie"
                          Click="NewGame_Click" />
                <MenuItem Header="_Quitter"
                          Click="Quit_Click" />
            </MenuItem>

            <MenuItem Header="_Mode">
                <MenuItem x:Name="LocalTwoPlayersMenuItem"
                          Header="_2 joueurs locaux"
                          IsCheckable="True"
                          IsChecked="True"
                          Click="LocalTwoPlayersMenuItem_Click" />
                <MenuItem x:Name="VersusCpuMenuItem"
                          Header="_Contre le CPU"
                          IsCheckable="True"
                          Click="VersusCpuMenuItem_Click" />
            </MenuItem>

            <MenuItem Header="_Couleur">
                <MenuItem x:Name="PlayWhiteMenuItem"
                          Header="Je joue les _Blancs"
                          IsCheckable="True"
                          IsChecked="True"
                          Click="PlayWhiteMenuItem_Click" />
                <MenuItem x:Name="PlayBlackMenuItem"
                          Header="Je joue les _Noirs"
                          IsCheckable="True"
                          Click="PlayBlackMenuItem_Click" />
            </MenuItem>

            <MenuItem Header="_Niveau CPU">
                <MenuItem x:Name="CpuLevel1MenuItem"
                          Header="_Niveau 1"
                          IsCheckable="True"
                          IsChecked="True"
                          Click="CpuLevel1MenuItem_Click" />
                <MenuItem x:Name="CpuLevel2MenuItem"
                          Header="Niveau _2"
                          IsCheckable="True"
                          Click="CpuLevel2MenuItem_Click" />
                <MenuItem x:Name="CpuLevel3MenuItem"
                          Header="Niveau _3"
                          IsCheckable="True"
                          Click="CpuLevel3MenuItem_Click" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock"
                           Style="{StaticResource StatusValueTextStyle}"
                           Text="Tour : Blancs" />
            </StatusBarItem>

            <Separator />

            <StatusBarItem>
                <TextBlock x:Name="SelectionTextBlock"
                           Style="{StaticResource StatusValueTextStyle}"
                           Text="Aucune sélection" />
            </StatusBarItem>

            <Separator />

            <StatusBarItem>
                <TextBlock x:Name="ViewModeTextBlock"
                           Style="{StaticResource StatusValueTextStyle}"
                           Text="Mode : 2 joueurs" />
            </StatusBarItem>
        </StatusBar>

        <Grid x:Name="Root"
              Background="{StaticResource WindowBackgroundBrush}"
              MouseLeftButtonDown="Root_MouseLeftButtonDown">
            <Border Margin="10"
                    CornerRadius="12"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1"
                    Background="#0F1113">
                <Viewport3D x:Name="Viewport"
                            ClipToBounds="True">
                    <Viewport3D.Camera>
                        <PerspectiveCamera x:Name="Camera"
                                           Position="0,10,13"
                                           LookDirection="0,-8,-13"
                                           UpDirection="0,1,0"
                                           FieldOfView="60" />
                    </Viewport3D.Camera>
                </Viewport3D>
            </Border>
        </Grid>
    </DockPanel>
</Window>