<Window x:Class="Chess3D.App.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chess 3D"
        Height="900"
        Width="1400"
        Background="#0B1016"
        Foreground="#E8EDF5"
        FontFamily="Segoe UI Variable Display, Segoe UI, Arial"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="WindowBgBrush" Color="#0B1016" />
        <SolidColorBrush x:Key="TopBarBrush" Color="#101823" />
        <SolidColorBrush x:Key="TopBarBorderBrush" Color="#1E2A38" />
        <SolidColorBrush x:Key="PopupBrush" Color="#14202C" />
        <SolidColorBrush x:Key="PopupBorderBrush" Color="#263748" />
        <SolidColorBrush x:Key="HoverBrush" Color="#1C2B3C" />
        <SolidColorBrush x:Key="PressedBrush" Color="#24374A" />
        <SolidColorBrush x:Key="AccentBrush" Color="#79B8FF" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#213C56" />
        <SolidColorBrush x:Key="StatusBarBrush" Color="#0E151E" />
        <SolidColorBrush x:Key="StatusBarBorderBrush" Color="#1A2532" />
        <SolidColorBrush x:Key="StatusChipBrush" Color="#15212E" />
        <SolidColorBrush x:Key="StatusChipBorderBrush" Color="#26384A" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8EDF5" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#AAB5C3" />
        <SolidColorBrush x:Key="TextDisabledBrush" Color="#6B7683" />
        <SolidColorBrush x:Key="SeparatorBrush" Color="#2B3C4F" />
        <SolidColorBrush x:Key="ViewportBorderBrush" Color="#1A2430" />

        <!-- Fenêtre -->
        <Style TargetType="{x:Type Window}">
            <Setter Property="Background" Value="{StaticResource WindowBgBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="Auto" />
        </Style>

        <!-- Barre de menu -->
        <Style TargetType="{x:Type Menu}">
            <Setter Property="Background" Value="{StaticResource TopBarBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TopBarBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <!-- Séparateurs -->
        <Style TargetType="{x:Type Separator}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="1"
                                Margin="10,6"
                                Background="{StaticResource SeparatorBrush}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- StatusBar -->
        <Style TargetType="{x:Type StatusBar}">
            <Setter Property="Background" Value="{StaticResource StatusBarBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StatusBarBorderBrush}" />
            <Setter Property="BorderThickness" Value="1,1,1,0" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="{x:Type StatusBarItem}">
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="{StaticResource StatusChipBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StatusChipBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type StatusBarItem}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusPrimaryTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="StatusMutedTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Style unifié des MenuItem -->
        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource TopBarBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Margin="3,0"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                </Grid.ColumnDefinitions>

                                <!-- Zone coche -->
                                <Grid x:Name="CheckHost"
                                      Grid.Column="0"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed">
                                    <Border x:Name="CheckBadge"
                                            Width="16"
                                            Height="16"
                                            CornerRadius="8"
                                            Background="Transparent"
                                            BorderBrush="{StaticResource AccentSoftBrush}"
                                            BorderThickness="1">
                                        <Path x:Name="CheckGlyph"
                                              Data="M 3 8 L 6.5 11.5 L 13 5"
                                              Stroke="{StaticResource AccentBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Visibility="Collapsed" />
                                    </Border>
                                </Grid>

                                <!-- Texte -->
                                <ContentPresenter x:Name="HeaderHost"
                                                  Grid.Column="1"
                                                  Margin="6,2,10,2"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"
                                                  ContentSource="Header" />

                                <!-- Flèche sous-menu -->
                                <Path x:Name="ArrowGlyph"
                                      Grid.Column="2"
                                      Data="M 5 4 L 9 8 L 5 12"
                                      Stroke="{StaticResource TextSecondaryBrush}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Width="14"
                                      Height="14"
                                      Stretch="None"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed" />

                                <!-- Popup -->
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Placement="Bottom"
                                       PopupAnimation="Fade">
                                    <Border x:Name="PopupBorder"
                                            Background="{StaticResource PopupBrush}"
                                            BorderBrush="{StaticResource PopupBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            Margin="0,8,0,0"
                                            SnapsToDevicePixels="True">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="18"
                                                              ShadowDepth="0"
                                                              Opacity="0.26"
                                                              Color="#000000" />
                                        </Border.Effect>

                                        <Grid>
                                            <Border Width="30"
                                                    HorizontalAlignment="Left"
                                                    Background="#172534"
                                                    CornerRadius="16,0,0,16"
                                                    IsHitTestVisible="False" />

                                            <StackPanel IsItemsHost="True"
                                                        Margin="8"
                                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                                        </Grid>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- Top-level header -->
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter Property="Background" Value="{StaticResource TopBarBrush}" />
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
                                <Setter TargetName="RootBorder" Property="Margin" Value="3,0" />
                                <Setter TargetName="HeaderHost" Property="Margin" Value="2,2,2,2" />
                                <Setter TargetName="CheckHost" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="ArrowGlyph" Property="Visibility" Value="Collapsed" />
                            </Trigger>

                            <!-- Top-level item -->
                            <Trigger Property="Role" Value="TopLevelItem">
                                <Setter Property="Background" Value="{StaticResource TopBarBrush}" />
                                <Setter TargetName="CheckHost" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="ArrowGlyph" Property="Visibility" Value="Collapsed" />
                            </Trigger>

                            <!-- Sous-menu item -->
                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="FontWeight" Value="Normal" />
                                <Setter TargetName="RootBorder" Property="Margin" Value="0,2" />
                                <Setter TargetName="HeaderHost" Property="Margin" Value="6,0,10,0" />
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Right" />
                                <Setter TargetName="PART_Popup" Property="HorizontalOffset" Value="8" />
                            </Trigger>

                            <!-- Sous-menu header -->
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="FontWeight" Value="Normal" />
                                <Setter TargetName="RootBorder" Property="Margin" Value="0,2" />
                                <Setter TargetName="HeaderHost" Property="Margin" Value="6,0,10,0" />
                                <Setter TargetName="ArrowGlyph" Property="Visibility" Value="Visible" />
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Right" />
                                <Setter TargetName="PART_Popup" Property="HorizontalOffset" Value="8" />
                            </Trigger>

                            <!-- Items cochables -->
                            <Trigger Property="IsCheckable" Value="True">
                                <Setter TargetName="CheckHost" Property="Visibility" Value="Visible" />
                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBadge" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter TargetName="CheckBadge" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>

                            <!-- Hover -->
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource HoverBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource AccentSoftBrush}" />
                            </Trigger>

                            <!-- Ouvert -->
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource PressedBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>

                            <!-- Désactivé -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextDisabledBrush}" />
                                <Setter TargetName="ArrowGlyph" Property="Stroke" Value="{StaticResource TextDisabledBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True"
               Background="{StaticResource WindowBgBrush}">

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Partie">
                <MenuItem Header="_Nouvelle partie"
                          Click="NewGame_Click" />
                <Separator />
                <MenuItem x:Name="VersusCpuMenuItem"
                          Header="Jouer contre le _CPU"
                          IsCheckable="True"
                          Click="VersusCpuMenuItem_Click" />
                <MenuItem x:Name="LocalTwoPlayersMenuItem"
                          Header="Mode _2 joueurs locaux"
                          IsCheckable="True"
                          Click="LocalTwoPlayersMenuItem_Click" />
                <Separator />
                <MenuItem x:Name="PlayWhiteMenuItem"
                          Header="Vous jouez les _Blancs"
                          IsCheckable="True"
                          Click="PlayWhiteMenuItem_Click" />
                <MenuItem x:Name="PlayBlackMenuItem"
                          Header="Vous jouez les _Noirs"
                          IsCheckable="True"
                          Click="PlayBlackMenuItem_Click" />
                <Separator />
                <MenuItem Header="_Quitter"
                          Click="Quit_Click" />
            </MenuItem>

            <MenuItem Header="_Niveau CPU">
                <MenuItem x:Name="CpuLevel1MenuItem" Header="Niveau _1" IsCheckable="True" Click="CpuLevel1MenuItem_Click" />
                <MenuItem x:Name="CpuLevel2MenuItem" Header="Niveau _2" IsCheckable="True" Click="CpuLevel2MenuItem_Click" />
                <MenuItem x:Name="CpuLevel3MenuItem" Header="Niveau _3" IsCheckable="True" Click="CpuLevel3MenuItem_Click" />
                <MenuItem x:Name="CpuLevel4MenuItem" Header="Niveau _4" IsCheckable="True" Click="CpuLevel4MenuItem_Click" />
                <MenuItem x:Name="CpuLevel5MenuItem" Header="Niveau _5" IsCheckable="True" Click="CpuLevel5MenuItem_Click" />
                <MenuItem x:Name="CpuLevel6MenuItem" Header="Niveau _6" IsCheckable="True" Click="CpuLevel6MenuItem_Click" />
                <MenuItem x:Name="CpuLevel7MenuItem" Header="Niveau _7" IsCheckable="True" Click="CpuLevel7MenuItem_Click" />
                <MenuItem x:Name="CpuLevel8MenuItem" Header="Niveau _8" IsCheckable="True" Click="CpuLevel8MenuItem_Click" />
                <MenuItem x:Name="CpuLevel9MenuItem" Header="Niveau _9" IsCheckable="True" Click="CpuLevel9MenuItem_Click" />
                <MenuItem x:Name="CpuLevel10MenuItem" Header="Niveau _10" IsCheckable="True" Click="CpuLevel10MenuItem_Click" />
            </MenuItem>

            <MenuItem Header="_Aide">
                <MenuItem Header="_À propos"
                          Click="About_Click" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock"
                           Style="{StaticResource StatusPrimaryTextStyle}"
                           Text="Tour : Blancs" />
            </StatusBarItem>

            <StatusBarItem>
                <TextBlock x:Name="SelectionTextBlock"
                           Style="{StaticResource StatusMutedTextStyle}"
                           Text="Aucune sélection" />
            </StatusBarItem>

            <StatusBarItem>
                <TextBlock x:Name="ViewModeTextBlock"
                           Style="{StaticResource StatusMutedTextStyle}"
                           Text="Mode : CPU — Vous jouez Blancs — Niveau 3" />
            </StatusBarItem>
        </StatusBar>

        <Border Margin="10"
                CornerRadius="14"
                BorderBrush="{StaticResource ViewportBorderBrush}"
                BorderThickness="1"
                Background="Black"
                SnapsToDevicePixels="True">
            <Grid x:Name="Root"
                  Background="Black"
                  MouseLeftButtonDown="Root_MouseLeftButtonDown">
                <Viewport3D x:Name="Viewport"
                            ClipToBounds="True">
                    <Viewport3D.Camera>
                        <PerspectiveCamera x:Name="Camera"
                                           Position="0,10,13"
                                           LookDirection="0,-8,-13"
                                           UpDirection="0,1,0"
                                           FieldOfView="60" />
                    </Viewport3D.Camera>
                </Viewport3D>
            </Grid>
        </Border>
    </DockPanel>
</Window>