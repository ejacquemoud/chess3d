<Window x:Class="Chess3D.App.Wpf.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:nav="clr-namespace:System.Windows.Navigation;assembly=PresentationFramework"
        Title="À propos"
        Width="520"
        Height="532"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#111214"
        Foreground="#EDEEF2"
        FontFamily="Segoe UI Variable Display, Segoe UI, Arial">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBgBrush" Color="#111214" />
        <SolidColorBrush x:Key="CardBrush" Color="#1A1C1F" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#2C2E34" />
        <SolidColorBrush x:Key="PanelBrush" Color="#17181C" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#252629" />
        <SolidColorBrush x:Key="AccentBrush" Color="#C9A84C" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#1C1A10" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#EDEEF2" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8E9098" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#555760" />
        <SolidColorBrush x:Key="ButtonBrush" Color="#1E2024" />
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#262830" />
        <SolidColorBrush x:Key="ButtonPressedBrush" Color="#2E3038" />
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#34363C" />

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="CaptionTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="TitleTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="FooterTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="12.5" />
        </Style>

        <Style TargetType="{x:Type Hyperlink}">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="TextDecorations" Value="{x:Static TextDecorations.Underline}" />
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource ButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="11"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource ButtonHoverBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource ButtonPressedBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBgBrush}">
        <Border Margin="16"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="18">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  ShadowDepth="0"
                                  Opacity="0.18"
                                  Color="#000000" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- En-tête -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="56"
                            Height="56"
                            CornerRadius="16"
                            Background="{StaticResource AccentSoftBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                        <Grid>
                            <Image x:Name="AppIconImage"
                               Width="36"
                               Height="36"
                               Stretch="Uniform"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="Chess 3D"
                                   Style="{StaticResource TitleTextStyle}" />

                        <TextBlock Text="Application d'échecs 3D en WPF"
                                   Margin="0,4,0,0"
                                   Style="{StaticResource CaptionTextStyle}" />

                        <Border Margin="0,10,0,0"
                                Padding="10,5"
                                Background="#1A1810"
                                BorderBrush="#38321E"
                                BorderThickness="1"
                                CornerRadius="8"
                                HorizontalAlignment="Left">
                            <TextBlock x:Name="VersionTextBlock"
                                       Text="Version"
                                       Style="{StaticResource CaptionTextStyle}" />
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Description -->
                <!-- Description -->
                <Border Grid.Row="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="16">
                                <TextBlock TextWrapping="Wrap"
                           LineHeight="20"
                           Style="{StaticResource CaptionTextStyle}">
                    <Run Text="Chess 3D est une application d'échecs avec affichage 3D intégral, partie locale et jeu contre le CPU via Stockfish (10 niveaux de difficulté)." />
                    <LineBreak />
                    <LineBreak />

                    <Run Text="L'application est gratuite et open-source 😊" />
                    <LineBreak />
                    <LineBreak />

                    <Run Text="Crédits :" />
                    <LineBreak />

                    <Run Text="• Code source : " />
                    <Hyperlink NavigateUri="https://github.com/ejacquemoud/chess3d"
                               RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="GitHub" />
                    </Hyperlink>
                    <LineBreak />

                    <Run Text="• Modèles 3D : " />
                    <Hyperlink NavigateUri="https://sketchfab.com/3d-models/realistic-3d-chess-pieces-blender-fbb81d5dc8854f41b6e2db6673daefb3"
                               RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="Realistic 3D Chess Pieces" />
                    </Hyperlink>
                    <Run Text=" — CC Attribution" />
                    <LineBreak />

                    <Run Text="• Moteur CPU : " />
                    <Hyperlink NavigateUri="https://stockfishchess.org"
                               RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="Stockfish" />
                    </Hyperlink>
                    </TextBlock>
                </Border>

                <!-- Footer intégré -->
                <Border Grid.Row="4"
                        Margin="0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="© 2026 Etienne Jacquemoud"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FooterTextStyle}" />

                        <Button Grid.Column="2"
                                Width="112"
                                HorizontalAlignment="Right"
                                Click="CloseButton_Click"
                                Content="Fermer" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
