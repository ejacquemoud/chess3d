<Window x:Class="Chess3D.App.Wpf.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="À propos"
        Width="520"
        Height="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="#0B1016"
        Foreground="#E8EDF5"
        FontFamily="Segoe UI Variable Display, Segoe UI, Arial">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBgBrush" Color="#0B1016" />
        <SolidColorBrush x:Key="CardBrush" Color="#121A24" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#243242" />
        <SolidColorBrush x:Key="AccentBrush" Color="#79B8FF" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#17314A" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8EDF5" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#AAB5C3" />
        <SolidColorBrush x:Key="ButtonBrush" Color="#172231" />
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#1F2E41" />
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#2A3C51" />

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="CaptionTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource ButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="2" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource ButtonHoverBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.92" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBgBrush}">
        <Border Margin="20"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- En-tête -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="56"
                            Height="56"
                            CornerRadius="16"
                            Background="{StaticResource AccentSoftBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                                            <Image x:Name="AppIconImage"
                               Width="28"
                               Height="28"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Chess 3D"
                                   FontSize="28"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Application d'échecs 3D en WPF"
                                   Margin="0,4,0,0"
                                   Style="{StaticResource CaptionTextStyle}" />
                        <TextBlock x:Name="VersionTextBlock"
                                   Text="Version"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource CaptionTextStyle}" />
                    </StackPanel>
                </Grid>

                <!-- Description -->
                <Border Grid.Row="2"
                        Background="#101722"
                        BorderBrush="#1E2B39"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="16">
                    <TextBlock TextWrapping="Wrap"
                               LineHeight="22"
                               Style="{StaticResource CaptionTextStyle}">
                        Chess 3D est une application d'échecs avec affichage 3D, partie locale et jeu contre le CPU via Stockfish (10 niveaux de difficulté).
                    </TextBlock>
                </Border>

                <!-- Infos -->
                <Grid Grid.Row="3"
                      Margin="0,18,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="#101722"
                            BorderBrush="#1E2B39"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Technologies"
                                       Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Text=".NET / WPF"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource ValueTextStyle}" />

                            <TextBlock Text="Moteur"
                                       Margin="0,14,0,0"
                                       Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Text="Stockfish"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource ValueTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#101722"
                            BorderBrush="#1E2B39"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Fonctionnalités"
                                       Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Text="Partie locale, CPU, affichage 3D"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource ValueTextStyle}" />

                            <TextBlock Text="Interface"
                                       Margin="0,14,0,0"
                                       Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Text="Thème sombre moderne"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource ValueTextStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Actions -->
                <DockPanel Grid.Row="4"
                           LastChildFill="False">
                    <TextBlock Text="© 2026 Etienne Jacquemoud"
                               VerticalAlignment="Center"
                               Style="{StaticResource CaptionTextStyle}" />

                    <Button Content="Fermer"
                            Width="110"
                            DockPanel.Dock="Right"
                            Click="CloseButton_Click" />
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>