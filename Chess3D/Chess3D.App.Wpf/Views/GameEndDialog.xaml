<Window x:Class="Chess3D.App.Wpf.Views.GameEndDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fin de partie"
        Width="420"
        Height="230"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        Background="#111214"
        Foreground="#EDEEF2"
        FontFamily="Segoe UI Variable Display, Segoe UI, Arial">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBgBrush" Color="#111214" />
        <SolidColorBrush x:Key="CardBrush" Color="#1A1C1F" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#2C2E34" />
        <SolidColorBrush x:Key="AccentBrush" Color="#C9A84C" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#EDEEF2" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8E9098" />
        <SolidColorBrush x:Key="ButtonBrush" Color="#1E2024" />
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#262830" />
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#34363C" />

        <Style x:Key="DialogTitleTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="DialogBodyTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource ButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="4,2" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource ButtonHoverBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBgBrush}">
        <Border Margin="18"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="22">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  ShadowDepth="0"
                                  Opacity="0.20"
                                  Color="#000000" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="TitleTextBlock"
                           Grid.Row="0"
                           Text="Fin de partie"
                           Style="{StaticResource DialogTitleTextStyle}" />

                <TextBlock x:Name="MessageTextBlock"
                           Grid.Row="2"
                           TextWrapping="Wrap"
                           LineHeight="22"
                           Style="{StaticResource DialogBodyTextStyle}" />

                <Button Grid.Row="4"
                        Content="OK"
                        Width="110"
                        HorizontalAlignment="Right"
                        Click="OkButton_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
